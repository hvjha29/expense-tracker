# --- Auth (remote multi-user) ---
# none  = local stdio (Claude Desktop / Gemini); no bearer required
# static = require Authorization: Bearer <token> from users.json
AUTH_MODE=static

# Path to multi-user config (default: ./users.json)
USERS_CONFIG=./users.json

# Used when AUTH_MODE=none
DEFAULT_USER_ID=alice

# Shorthand alternative to users.json (AUTH_MODE=static):
# AUTH_TOKENS=alice:long-token-1,bob:long-token-2

# --- Supabase Postgres (required) ---
# Project Settings → Database → Connection string (URI)
# Prefer Session pooler for a long-running MCP server.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Transport (remote) ---
# MCP_TRANSPORT=sse
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# --- Shared Gmail OAuth client ---
# Put credentials.json in the project root, OR provide the JSON string here:
# GMAIL_CREDENTIALS_JSON={...}   

# Use this to specify the base URL for the OAuth callback if running behind a proxy
# OAUTH_REDIRECT_URI=https://your-app-url.com/auth/callback

# --- Airtel POC clients (optional) ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1
